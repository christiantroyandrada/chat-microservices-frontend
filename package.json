{
	"name": "chat-microservices-frontend",
	"private": true,
	"version": "0.0.2",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"coverage:unit": "vitest --coverage --run",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.3",
		"@testing-library/svelte": "^5.4.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.19.7",
		"@vitest/browser": "^3.2.7",
		"@vitest/coverage-v8": "^3.2.7",
		"cookie": "^0.7.2",
		"eslint": "^9.39.5",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.22.0",
		"globals": "^16.5.0",
		"happy-dom": "^20.11.1",
		"js-yaml": "^4.1.1",
		"playwright": "^1.61.1",
		"postcss-nesting": "^11.3.0",
		"prettier": "^3.9.6",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.56.7",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.1",
		"vite": "^7.3.6",
		"vitest": "^3.2.7",
		"vitest-browser-svelte": "^1.1.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"@tailwindcss/oxide"
		],
		"overrides": {
			"cookie": "^0.7.0",
			"rollup@4": ">=4.59.0",
			"devalue": ">=5.8.1",
			"protobufjs": "^7.6.5",
			"ws": "^8.21.0",
			"socket.io-parser": "^4.2.6",
			"flatted": ">=3.4.2",
			"picomatch@4": ">=4.0.4"
		}
	},
	"dependencies": {
		"@fontsource-variable/hanken-grotesk": "^5.3.0",
		"@fontsource-variable/spline-sans-mono": "^5.3.0",
		"@fontsource/spectral": "^5.3.0",
		"@privacyresearch/libsignal-protocol-typescript": "^0.0.16",
		"prom-client": "^15.1.3",
		"socket.io-client": "^4.8.3"
	}
}
